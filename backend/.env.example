# MusicTrack — Backend env
# Copiá este archivo a .env.local y completá los valores reales.

# --- Supabase ---
# URL pública del proyecto Supabase.
NEXT_PUBLIC_SUPABASE_URL=
# Publishable / anon key. Las policies de RLS controlan el acceso.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- CORS ---
# Lista de orígenes permitidos (frontend), separados por coma. Usar "*" sólo en dev.
ALLOWED_ORIGINS=http://localhost:3000,https://musictrack.vercel.app

# --- Mercado Pago ---
# Access token de la aplicación. Sandbox: TEST-... | Producción: APP_USR-...
# SECRETO: nunca exponer al cliente ni loguear.
MP_ACCESS_TOKEN=
# Public key (sólo necesaria si en el futuro renderizamos Bricks en el frontend).
MP_PUBLIC_KEY=
# Secret del webhook (Dashboard MP → Tus integraciones → Webhooks → Clave secreta).
MP_WEBHOOK_SECRET=

# --- URLs para back_urls y notification_url de Mercado Pago ---
# URL pública del frontend (a donde redirige MP tras el pago).
FRONTEND_URL=http://localhost:3000
# URL pública del backend (a donde MP envía el webhook).
# En dev local usar un túnel (ngrok / cloudflared) ya que MP necesita HTTPS público.
BACKEND_PUBLIC_URL=http://localhost:3001
