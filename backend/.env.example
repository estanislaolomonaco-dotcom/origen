# MusicTrack — Variables de entorno (frontend)
# Copiá este archivo a .env.local y completá los valores reales.
#
# Si dejás estas variables vacías, la app sigue funcionando con los
# productos mock locales (src/data/products.js). En cuanto las completes,
# todas las páginas pasan a leer de Supabase automáticamente.

# URL pública del proyecto Supabase (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (Project Settings → API → "anon public" o "publishable key")
# Es PÚBLICA por diseño — RLS controla los permisos en el server.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
